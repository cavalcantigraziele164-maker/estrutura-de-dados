#include <stdio.h>
// Função para preencher um array com valores
void preencherArray(int *arr, int tamanho) {
 for (int i = 0; i < tamanho; i++) {
 *(arr + i) = i * 2; // exemplo i=1 arr + 1= 1*2=2, meuArray[1]=2
}
}
// Função para exibir os elementos de um array
void exibirArray(int *arr, int tamanho) {
 printf("Conteúdo do array: ");
 for (int i = 0; i < tamanho; i++) {
 printf("%d ", *(arr + i)); //mostrar cada posição do vetor
 }
 printf("\n");
}
int main() {
 const int TAMANHO = 5;
 int meuArray[TAMANHO];//declarou o tamanho pra poder chamar as funções e ter o valor correto
 // Preencher o array usando ponteiros
 preencherArray(meuArray, TAMANHO);
 // Exibir o array usando ponteiros
 exibirArray(meuArray, TAMANHO); // chamou a função para mostrar os valores do meuArray
 return 0;
}
