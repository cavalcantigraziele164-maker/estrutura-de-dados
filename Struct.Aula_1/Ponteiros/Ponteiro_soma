#include <stdio.h>
// Função para calcular a soma dos elementos de um array
void calcularSoma(int *arr, int tamanho, int *resultado) { //arr aponta para o primeiro elemento do vetor
 *resultado = 0; // inicialmente é 0(aqui é o valor que está no endereço resultado, que é a soma.) = resultado=&soma e *resultado=0, soma =0.
 for (int i = 0; i < tamanho; i++) {
 *resultado += arr[i]; // *resultado = *resultado + arr[i] , *resultado=0, aí i=0, *resultado= 0+1= 1
 }
}
int main() {
 const int TAMANHO = 5;
 int meuArray[TAMANHO] = {1, 2, 3, 4, 5};
 int soma = 0;
 // Chamando a função calcularSoma e passando o array e seu tamanho por
referência
 calcularSoma(meuArray, TAMANHO, &soma);
 // Exibindo o resultado da soma
 printf("A soma dos elementos do array é: %d\n", soma);//*resultado=soma
 return 0;
}
