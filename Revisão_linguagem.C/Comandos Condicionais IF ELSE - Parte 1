#include<stdio.h>
int main (void){
	int num;
	printf("Informe o numero.");
	scanf("%d", &num);
	
	if(num%2==0){
	printf("O numero %d eh par.", num);
	}
	else{
		printf("O numero %d eh impar.", num);
	}
	
	return 0;
}




